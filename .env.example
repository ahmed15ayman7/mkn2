# Copy to `.env` and adjust. Never commit secrets.

DATABASE_URL="postgresql://mkn:mkn@localhost:5432/mkn?schema=public"

# Public site URL (canonical, OG, sitemap)
NEXT_PUBLIC_SITE_URL="https://mkn.ahmed15ayman7.com"
# Optional — defaults to ${NEXT_PUBLIC_SITE_URL}/logo-mkn.png
# NEXT_PUBLIC_OG_IMAGE_URL="https://mkn.ahmed15ayman7.com/logo-mkn.png"
# NEXT_PUBLIC_TWITTER_HANDLE="@mkn"

NEXT_PUBLIC_HERO_VIDEO_URL="https://real.com.eg/mkn/files/video-mkn.mp4"
# NEXT_PUBLIC_IMAGE_ALLOWLIST="cdn.example.com"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Google OAuth (optional — enables “Continue with Google” on /admin/login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
