// Dual-language content for MKN Developments public site + CMS

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum InquiryStatus {
  NEW
  READ
  ARCHIVED
}

enum UserRole {
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          UserRole  @default(ADMIN)
  active        Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id              String    @id @default(cuid())
  slug            String    @unique
  titleAr         String
  titleEn         String
  descAr          String    @db.Text
  descEn          String    @db.Text
  locationAr      String
  locationEn      String
  areaSqm         Decimal?  @db.Decimal(14, 2)
  completionDate  DateTime?
  investmentValue Decimal?  @db.Decimal(18, 2)
  videoUrl        String?
  coverImage      String
  images          String[]  @default([])
  featured        Boolean   @default(false)

  // Project detail page (Sea Point layout)
  heroSubtitleEn      String?
  heroSubtitleAr      String?
  deliveryTitleEn     String?
  deliveryTitleAr     String?
  deliveryBody1En     String?  @db.Text
  deliveryBody1Ar     String?  @db.Text
  deliveryBody2En     String?  @db.Text
  deliveryBody2Ar     String?  @db.Text
  deliveryVideoUrl    String?
  deliveryCtaEn       String?
  deliveryCtaAr       String?
  brochureUrl         String?
  panoramicImageUrl   String?
  coastalTitleEn      String?  @db.Text
  coastalTitleAr      String?  @db.Text
  coastalCol1En       String?  @db.Text
  coastalCol1Ar       String?  @db.Text
  coastalCol2En       String?  @db.Text
  coastalCol2Ar       String?  @db.Text
  coastalCol3En       String?  @db.Text
  coastalCol3Ar       String?  @db.Text
  coastalHighlightEn  String?  @db.Text
  coastalHighlightAr  String?  @db.Text
  galleryImages       String[] @default([])
  mapImageUrl         String?
  mapLogoUrl          String?
  locationBlurbEn     String?  @db.Text
  locationBlurbAr     String?  @db.Text
  locationLabelEn     String?
  locationLabelAr     String?
  luxuryTitleEn       String?  @db.Text
  luxuryTitleAr       String?  @db.Text
  luxuryCol1En        String?  @db.Text
  luxuryCol1Ar        String?  @db.Text
  luxuryCol2En        String?  @db.Text
  luxuryCol2Ar        String?  @db.Text
  closingImageUrl     String?
  facilitiesTitleEn   String?
  facilitiesTitleAr   String?
  facilitiesEn        String[] @default([])
  facilitiesAr        String[] @default([])
  /// [{ titleEn, titleAr, descEn, descAr, imageUrl?, variant? }]
  amenities           Json     @default("[]")

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  seo SeoMetadata?
}

model Partner {
  id         String   @id @default(cuid())
  nameAr     String
  nameEn     String
  logoUrl    String
  websiteUrl String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
}

/// SEO for a project (1:1) or a static page path (e.g. "about"). Exactly one target should be set at the app layer.
model SeoMetadata {
  id          String @id @default(cuid())
  projectId   String? @unique
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pagePath    String? @unique

  metaTitleAr String
  metaTitleEn String
  metaDescAr  String @db.Text
  metaDescEn  String @db.Text
  keywordsAr  String[] @default([])
  keywordsEn  String[] @default([])
  ogImage     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GlobalContent {
  id        String   @id @default(cuid())
  key       String   @unique
  valueAr   String   @db.Text
  valueEn   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inquiry {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  phone        String
  subject      String?
  targetBudget String?
  message      String        @db.Text
  status       InquiryStatus @default(NEW)
  createdAt    DateTime      @default(now())
}
